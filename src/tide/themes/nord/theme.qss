/* tide :: nord — polar restraint */

* {
    font-family: "@font_family", sans-serif;
    font-size: @font_size;
    color: @fg;
}

QMainWindow, QDialog, QWidget {
    background: @bg;
    color: @fg;
}

QLabel { background: transparent; color: @fg; }
QLabel#dim, QLabel.dim { color: @dim; }
QLabel#accent, QLabel.accent { color: @accent; }

QLineEdit {
    background: @bg_alt;
    color: @fg;
    border: @border solid @border_dim;
    border-radius: @radius;
    padding: 7px 12px;
    selection-background-color: @accent;
    selection-color: @bg;
}
QLineEdit:focus { border-color: @accent; }

QPushButton {
    background: @bg_alt;
    color: @fg;
    border: @border solid @border_col;
    border-radius: @radius;
    padding: 6px 14px;
}
QPushButton:hover { background: @accent; color: @bg; }
QPushButton:disabled { color: @dim; border-color: @border_dim; }

QComboBox {
    background: @bg_alt;
    color: @fg;
    border: @border solid @border_col;
    border-radius: @radius;
    padding: 6px 10px;
}
QComboBox QAbstractItemView {
    background: @bg_alt;
    color: @fg;
    selection-background-color: @accent;
    selection-color: @bg;
    border: @border solid @border_col;
    outline: 0;
}

QListView, QListWidget {
    background: @bg;
    color: @fg;
    border: none;
    outline: 0;
    padding: 4px 0;
}
QListView::item, QListWidget::item {
    padding: 7px 14px;
    border-radius: 4px;
    margin: 1px 4px;
}
QListView::item:hover, QListWidget::item:hover { background: @hover_bg; }
QListView::item:selected, QListWidget::item:selected { background: @accent; color: @bg; }

QScrollBar:vertical, QScrollBar:horizontal {
    background: transparent;
    width: 10px;
    height: 10px;
    margin: 0;
}
QScrollBar::handle:vertical, QScrollBar::handle:horizontal {
    background: @border_col;
    border-radius: 5px;
    min-height: 30px;
    min-width: 30px;
}
QScrollBar::handle:hover { background: @dim; }
QScrollBar::add-line, QScrollBar::sub-line { width: 0; height: 0; }

QStatusBar { background: @bg; color: @dim; border: 0; }
QStatusBar::item { border: 0; }

QToolTip {
    background: @bg_alt;
    color: @fg;
    border: @border solid @border_col;
    padding: 5px 10px;
    border-radius: @radius;
}

QMenu {
    background: @bg_alt;
    color: @fg;
    border: @border solid @border_col;
    border-radius: @radius;
    padding: 6px 0;
}
QMenu::item { padding: 6px 20px; background: transparent; }
QMenu::item:selected { background: @accent; color: @bg; }
QMenu::separator { height: 1px; background: @border_dim; margin: 4px 8px; }

QFrame#now_playing {
    background: @bg_alt;
    border-top: @border solid @border_col;
}
QFrame#nav {
    background: @bg_alt;
    border-right: @border solid @border_col;
}
